#!/bin/sh
# ============================================================
# Pre-push hook: valida que el proyecto buildea antes de push
# ============================================================
# Instalación: git config core.hooksPath .githooks
# (ya configurado automáticamente por npm prepare)

echo ""
echo "🔍  Pre-push: verificando que el build funciona..."
echo ""

npm run build

if [ $? -ne 0 ]; then
  echo ""
  echo "❌  BUILD FALLIDO — el push fue cancelado."
  echo "    Corrige los errores antes de hacer push."
  echo ""
  exit 1
fi

echo ""
echo "✅  Build exitoso — procediendo con el push."
echo ""
exit 0
